{
  "name": "bulgarche-desktop",
  "version": "4.0.0",
  "description": "Bulgarche Language Learning App - Desktop Version",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.bulgarche.desktop",
    "productName": "Bulgarche Desktop",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "public/**/*",
      "audiofiles/**/*",
      "txt/**/*",
      "icon/**/*",
      "main.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
