{
  "name": "bulgarche-desktop",
  "version": "4.0.0",
  "description": "Bulgarche Desktop",
  "main": "main-force-desktop.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.bulgarche.desktop",
    "productName": "Bulgarche Desktop",
    "directories": {
      "output": "dist-force"
    },
    "files": [
      "main-force-desktop.js",
      "preload.js",
      "public/**/*",
      "txt/**/*",
      "audiofiles/**/*",
      "icon/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon/bulgarche-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bulgarche Desktop"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
